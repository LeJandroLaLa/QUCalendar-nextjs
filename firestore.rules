rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
    }
    match /events/{eventId} {
      allow create: if request.auth != null;
      allow update, delete: if request.auth.token.email == 'jandro44@gmail.com';
    }
    match /venues/{venueId} {
      allow create: if request.auth != null;
      allow update, delete: if request.auth.token.email == 'jandro44@gmail.com';
    }
    match /artists/{artistId} {
      allow create: if request.auth != null;
      allow update, delete: if request.auth.token.email == 'jandro44@gmail.com';
    }
    match /spaces/{spaceId} {
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerUid;
      match /vault_entries/{entryId} {
        allow write: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/spaces/$(spaceId)).data.ownerUid ||
          (request.resource.data.contributorUid == request.auth.uid && request.resource.data.visibility == 'private')
        );
      }
    }
  }
}
